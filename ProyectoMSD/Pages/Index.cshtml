@page
@model IndexModel
@{
    ViewData["Title"] = "Bienvenido a MySmartDevice";
    ViewData["ShowNavbar"] = false; 
}

@section Styles {
    <link href="~/css/pages/login.css" rel="stylesheet" />
}

<div class="container-fluid login-container">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-11">
            <div class="card login-card">
                <div class="row g-0">
                    <!-- Sección de Bienvenida (Logo) -->
                    <div class="col-lg-6 logo-section d-flex flex-column justify-content-center">
                        <div class="robot-icon">
                            <div class="floating-icons">
                                <div class="floating-icon icon-thermometer"><i class="fas fa-thermometer-half"></i></div>
                                <div class="floating-icon icon-camera"><i class="fas fa-video"></i></div>
                                <div class="floating-icon icon-bulb"><i class="fas fa-lightbulb"></i></div>
                                <div class="floating-icon icon-plug"><i class="fas fa-plug"></i></div>
                            </div>
                            <div class="robot-face">
                                <div class="robot-eyes">
                                    <div class="robot-eye"></div>
                                    <div class="robot-eye"></div>
                                </div>
                            </div>
                        </div>
                        <h1 class="brand-text">My<span class="smart">Smart</span>Device</h1>
                        <p class="text-muted mt-2 fs-5">Control inteligente para tu hogar</p>
                    </div>

                    <!-- Sección de Información y Acciones -->
                    <div class="col-lg-6 login-form-container d-flex flex-column justify-content-center text-center">
                        <div class="mb-5">
                            <h2 class="form-title">El futuro de tu hogar, hoy.</h2>
                            <p class="form-subtitle mb-4">Controla, monitorea y automatiza todos tus dispositivos desde una única plataforma intuitiva y segura.</p>
                        </div>
                        
                        <div class="d-grid gap-3 col-md-8 mx-auto">
                            <a asp-page="/Login" class="btn btn-purple-glow btn-lg">
                                <i class="fas fa-sign-in-alt me-2"></i> Iniciar Sesión
                            </a>
                            <a asp-page="/Registrar" class="btn btn-login btn-lg text-white" style="border-radius: 24px;">
                                <i class="fas fa-user-plus me-2"></i> Crear una Cuenta
                            </a>
                        </div>
                        
                        <div class="mt-5 text-muted small">
                            <p class="mb-1"><i class="fas fa-shield-alt text-success me-1"></i> Máxima seguridad y encriptación</p>
                            <p class="mb-0"><i class="fas fa-bolt text-warning me-1"></i> Eficiencia energética garantizada</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
